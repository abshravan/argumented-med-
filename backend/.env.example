# ---------------------------------------------------------------
# MediAssist backend configuration
# Copy to `.env` and fill in the provider you want to use.
# ---------------------------------------------------------------

# Which provider to use by default: "gemini" or "openrouter"
LLM_PROVIDER=gemini

# ---- Google Gemini ----
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# Popular models return 503 "high demand" more often. gemini-2.0-flash is a
# dependable default. Check what your key can use:
#   curl "http://localhost:8000/api/models?provider=gemini"
GEMINI_MODEL=gemini-2.0-flash
# Tried in order if the primary model is overloaded/unavailable.
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite

# ---- OpenRouter ----
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Any OpenRouter model slug, e.g.
#   anthropic/claude-sonnet-4.5
#   google/gemini-2.0-flash-001
#   openai/gpt-4o-mini
#   meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers shown on openrouter.ai rankings
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=MediAssist Clinical Workspace

# ---- Generation ----
# One request per chat message: the model returns the narrative AND the insights
# JSON in a single call, so this needs enough headroom for both.
TEMPERATURE=0.2
MAX_OUTPUT_TOKENS=3500

# ---- Resilience ----
# Attempts against the primary model before trying the fallbacks. Only transient
# errors (503/429/timeouts) are retried; bad keys and bad model ids fail fast.
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_DELAY=1.5

# ---- Server ----
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
