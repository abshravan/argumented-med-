# ---------------------------------------------------------------
# MediAssist backend configuration
# Copy to `.env` and fill in the provider you want to use.
# ---------------------------------------------------------------

# Which provider to use by default: "gemini" or "openrouter"
LLM_PROVIDER=gemini

# ---- Google Gemini ----
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# Popular models return 503 "high demand" more often. gemini-2.0-flash is a
# dependable default. Check what your key can use:
#   curl "http://localhost:8000/api/models?provider=gemini"
GEMINI_MODEL=gemini-2.0-flash
# Tried in order if the primary model is overloaded. Leave EMPTY unless you have
# confirmed your project has quota for these — a model with "limit: 0" just burns
# time and requests. Check with /api/models and your Google AI Studio quota page.
GEMINI_FALLBACK_MODELS=

# ---- OpenRouter ----
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Any OpenRouter model slug, e.g.
#   anthropic/claude-sonnet-4.5
#   google/gemini-2.0-flash-001
#   openai/gpt-4o-mini
#   meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers shown on openrouter.ai rankings
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=MediAssist Clinical Workspace

# ---- Generation ----
# One request per chat message: the model returns the narrative AND the insights
# JSON in a single call, so this needs plenty of headroom.
#
# IMPORTANT for thinking models (gemini-2.5-*, gemini-3.*): this budget also covers
# reasoning tokens. Set it too low and the model burns the budget thinking and stops
# before writing the insights JSON — you'll see "contained no ---INSIGHTS--- block".
TEMPERATURE=0.2
MAX_OUTPUT_TOKENS=8192

# Gemini only, and NOT supported by every model.
#   gemini-2.5-flash : 0 disables reasoning (leaves the whole budget for the answer)
#   gemini-3.x       : REJECTS this parameter with a 400 Bad Request — leave blank
# Leave blank unless you know your model accepts it. A large MAX_OUTPUT_TOKENS is
# usually enough on its own. (If it is set and the model 400s, we retry without it.)
GEMINI_THINKING_BUDGET=

# ---- Resilience ----
# Attempts against the primary model before trying the fallbacks. Only transient
# errors (503/429/timeouts) are retried; bad keys and bad model ids fail fast.
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_DELAY=1.5
# Retries inside the provider SDK. Keep low: the Google SDK backs off for 30s+ on
# 429s, which stacks on top of our retry loop and hangs the request.
LLM_SDK_MAX_RETRIES=1
# Hard ceiling for one consultation, so the UI can never hang indefinitely.
LLM_REQUEST_BUDGET_SECONDS=60

# ---- Server ----
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
