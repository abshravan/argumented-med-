# ---------------------------------------------------------------
# MediAssist backend configuration
# Copy to `.env` and fill in the provider you want to use.
# ---------------------------------------------------------------

# Which provider to use by default: "gemini" or "openrouter"
LLM_PROVIDER=gemini

# ---- Google Gemini ----
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- OpenRouter ----
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Any OpenRouter model slug, e.g.
#   anthropic/claude-sonnet-4.5
#   google/gemini-2.0-flash-001
#   openai/gpt-4o-mini
#   meta-llama/llama-3.3-70b-instruct
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers shown on openrouter.ai rankings
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=MediAssist Clinical Workspace

# ---- Generation ----
TEMPERATURE=0.2
MAX_OUTPUT_TOKENS=2048

# ---- Server ----
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
